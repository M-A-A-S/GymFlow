@model ProductAddUpdateVM

@using GymFlow.Domain.DTOs.Product
@using GymFlow.Domain.Resources.Shared
@using GymFlow.WebUI.ViewModels.Product
@using Microsoft.Extensions.Localization
@using System.Globalization
@using System.Web
@using System.Text.Json
@inject IStringLocalizer<SharedResource> Localizer

<div class="card shadow-sm">

    <div class="card-header">
        <h5>@Localizer["Create"] @Localizer["Product"]</h5>
    </div>

    <div class="card-body">

        <form asp-action="Create" method="post" enctype="multipart/form-data">

            <partial name="Partials/_ProductForm" model="Model" />

            <button type="submit" class="btn btn-success">
                @Localizer["Save"]
            </button>

            <a asp-action="Index" class="btn btn-secondary">
                @Localizer["Cancel"]
            </a>

        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>

        $(function () {

            initializeCategory({

                categoryPlaceholder:
                    '@Localizer["SelectCategory"]',

                categoryId:
                    '@Model.Product.CategoryId',

            });

        });

    </script>
}